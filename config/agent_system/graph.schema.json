{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentSystemGraph",
  "type": "object",
  "required": ["metadata", "nodes", "edges"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "updated_at": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "name"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "Role",
              "Agent",
              "Human",
              "Artifact",
              "Rule",
              "Decision",
              "ChangeSet",
              "Process",
              "Policy",
              "WorkflowState",
              "HandoffNode",
              "ContextNode"
            ]
          },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "owner": { "type": "string" },
          "path": { "type": "string" },
          "notes": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "goal": { "type": "string", "description": "Goal for WorkflowState/HandoffNode" },
          "phase": { "type": "string", "description": "Current phase for WorkflowState" },
          "changes": { "type": "string", "description": "Changes description for HandoffNode" },
          "evidence": { "type": "string", "description": "Evidence for HandoffNode" },
          "risks": { "type": "string", "description": "Risks for HandoffNode" },
          "next_owner": { "type": "string", "description": "Next owner for HandoffNode" },
          "content": { "type": "string", "description": "Content for ContextNode" },
          "created_at": { "type": "string", "description": "Creation timestamp" },
          "workflow_id": { "type": "string", "description": "Reference to parent workflow" }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "type": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
