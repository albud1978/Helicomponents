{
  "version": 9,
  "architecture": "LIMITER V9 (message-based, 18 RTC + 1 HF_StepController)",
  "matrix": {
    "from": "state",
    "to": "state"
  },
  "states": {
    "0": "spawn (boundary)",
    "1": "inactive",
    "2": "operations",
    "3": "serviceable",
    "4": "repair",
    "5": "reserve (–љ–µ –Є—Б–њ–Њ–ї—М–Ј—Г–µ—В—Б—П –≤ V9, —А—Г–і–Є–Љ–µ–љ—В V2)",
    "6": "storage (terminal)",
    "7": "unserviceable"
  },
  "variables": [
    "state",
    "ticket",
    "intent_state",
    "sne",
    "ppr",
    "dt_next",
    "ll",
    "oh",
    "br",
    "limiter",
    "repair_days",
    "repair_time",
    "repair_line_id",
    "free_days",
    "group_by",
    "current_day",
    "exit_date",
    "idx",
    "threshold_s3",
    "threshold_s7",
    "demote_threshold",
    "quota_left",
    "line_id",
    "acn",
    "adaptive_days",
    "spawn_dynamic_need_mi8",
    "spawn_dynamic_need_mi17",
    "spawn_need_u32"
  ],
  "derived": [
    {
      "name": "sne_next",
      "expr": "sne + dt_next"
    },
    {
      "name": "ppr_next",
      "expr": "ppr + dt_next"
    }
  ],

  "init_at_model_build": {
    "description": "–Ш–љ–Є—Ж–Є–∞–ї–Є–Ј–∞—Ж–Є—П –≤—Л–њ–Њ–ї–љ—П–µ—В—Б—П –≤ Python –Ф–Ю simulate(), –Ј–∞–Љ–µ–љ—П–µ—В —Б—В–∞—А—Л–µ HostFunction layers 0, 1, 13",
    "items": [
      "mp5_cumsum MacroProperty вАФ –Ј–∞–њ–Њ–ї–љ–Є—В—М –Є–Ј Python-—Б–њ–Є—Б–Ї–∞ –Ї—Г–Љ—Г–ї—П—В–Є–≤–љ—Л—Е —З–∞—Б–Њ–≤",
      "deterministic_dates_mp вАФ –Ј–∞–њ–Њ–ї–љ–Є—В—М –Є–Ј —Д–Є–љ–∞–ї–Є–Ј–Є—А–Њ–≤–∞–љ–љ–Њ–≥–Њ —Б–њ–Є—Б–Ї–∞ –і–∞—В",
      "RepairLine –∞–≥–µ–љ—В—Л вАФ —Б–Њ–Ј–і–∞—В—М repair_quota —И—В—Г–Ї, day-0 –Ј–∞–љ—П—В—Л–µ –њ—А–Є–≤—П–Ј–∞—В—М –Ї –∞–≥–µ–љ—В–∞–Љ –≤ state 4",
      "mp_min_limiter = 0xFFFFFFFF, current_day_mp, adaptive_result_mp вАФ –Є–љ–Є—Ж–Є–∞–ї–Є–Ј–Є—А–Њ–≤–∞—В—М"
    ]
  },

  "rtc_execution_order": [
    {
      "order": 0,
      "phase": "–§–Р–Ч–Р 0: –Ф–µ—В–µ—А–Љ–Є–љ–Є—А–Њ–≤–∞–љ–љ—Л–µ –њ–µ—А–µ—Е–Њ–і—Л",
      "layer": "repair_to_svc",
      "function": "rtc_repair_to_svc_v7",
      "state": "4вЖТ3",
      "notes": "repairвЖТserviceable –њ–Њ exit_date. PPR=0, limiter=0."
    },
    {
      "order": 1,
      "phase": "–§–Р–Ч–Р 0: –Ф–µ—В–µ—А–Љ–Є–љ–Є—А–Њ–≤–∞–љ–љ—Л–µ –њ–µ—А–µ—Е–Њ–і—Л",
      "layer": "spawn_to_svc",
      "function": "rtc_spawn_to_svc",
      "state": "0вЖТ3",
      "notes": "–Ф–µ—В–µ—А–Љ–Є–љ–Є—А–Њ–≤–∞–љ–љ—Л–є spawn –њ–Њ exit_date вЖТ serviceable. PPR=0, SNE=0, limiter=0. P1 –њ–Њ–і–љ–Є–Љ–µ—В –≤ ops."
    },
    {
      "order": 2,
      "phase": "–§–Р–Ч–Р 1: Operations –Є —А–µ–Љ–Њ–љ—В–љ—Л–µ —Б—З—С—В—З–Є–Ї–Є",
      "layer": "ops_increment",
      "function": "rtc_ops_increment_v8",
      "state": "2вЖТ2",
      "notes": "SNE+=dt, PPR+=dt, limiter-=adaptive_days. dt –Є–Ј mp5_cumsum (–∞–і–∞–њ—В–Є–≤–љ—Л–є)."
    },
    {
      "order": 3,
      "phase": "–§–Р–Ч–Р 1: Operations –Є —А–µ–Љ–Њ–љ—В–љ—Л–µ —Б—З—С—В—З–Є–Ї–Є",
      "layer": "unsvc_decrement",
      "function": "rtc_unsvc_decrement_v8",
      "state": "7вЖТ7",
      "notes": "repair_days-=adaptive_days. –Ю–±—А–∞—В–љ—Л–є –Њ—В—Б—З—С—В —А–µ–Љ–Њ–љ—В–љ–Њ–≥–Њ –Њ–Ї–љ–∞."
    },
    {
      "order": 4,
      "phase": "–§–Р–Ч–Р 1: Operations –Є —А–µ–Љ–Њ–љ—В–љ—Л–µ —Б—З—С—В—З–Є–Ї–Є",
      "layer": "ops_to_storage",
      "function": "rtc_ops_to_storage_v8",
      "state": "2вЖТ6",
      "notes": "cond: limiter==0 + sne>=LL. Early-out: if limiter>0 return false."
    },
    {
      "order": 5,
      "phase": "–§–Р–Ч–Р 1: Operations –Є —А–µ–Љ–Њ–љ—В–љ—Л–µ —Б—З—С—В—З–Є–Ї–Є",
      "layer": "ops_to_unsvc",
      "function": "rtc_ops_to_unsvc_v8",
      "state": "2вЖТ7",
      "notes": "cond: limiter==0 + ppr>=OH + sne<BR. –£—Б—В–∞–љ–∞–≤–ї–Є–≤–∞–µ—В repair_days=repair_time. Early-out: if limiter>0 return false."
    },
    {
      "order": 6,
      "phase": "–§–Р–Ч–Р 1.5: RepairLine pre-quota",
      "layer": "repair_line_increment",
      "function": "rtc_repair_line_increment_v8",
      "state": "RepairLine",
      "notes": "free_days+=adaptive_days."
    },
    {
      "order": 7,
      "phase": "–§–Р–Ч–Р 1.5: RepairLine pre-quota",
      "layer": "repair_line_publish",
      "function": "rtc_repair_line_publish_status_v8",
      "state": "RepairLine",
      "notes": "message RepairLineStatus: line_id, free_days. –Ґ–Њ–ї—М–Ї–Њ –µ—Б–ї–Є free_days>=repair_time."
    },
    {
      "order": 8,
      "phase": "–§–Р–Ч–Р 2: –Ъ–≤–Њ—В–Є—А–Њ–≤–∞–љ–Є–µ (message-based)",
      "layer": "publish_planer_report",
      "function": "rtc_publish_planer_report",
      "state": "all",
      "notes": "–Ъ–∞–ґ–і—Л–є –∞–≥–µ–љ—В –њ—Г–±–ї–Є–Ї—Г–µ—В —Б—В–∞—В—Г—Б —З–µ—А–µ–Ј MessageBucket/MessageArray. –Ґ–Є–њ —Г—В–Њ—З–љ–Є—В—М –њ—А–Є —А–µ–∞–ї–Є–Ј–∞—Ж–Є–Є QM."
    },
    {
      "order": 9,
      "phase": "–§–Р–Ч–Р 2: –Ъ–≤–Њ—В–Є—А–Њ–≤–∞–љ–Є–µ (message-based)",
      "layer": "QM_central_decision",
      "function": "rtc_quota_manager_v9",
      "state": "QM",
      "notes": "QM —З–Є—В–∞–µ—В PlanerReport + RepairLineStatus. –Ъ–∞—Б–Ї–∞–і–љ—Л–є –і–µ—Д–Є—Ж–Є—В: demoteвЖТP1вЖТP2вЖТP3вЖТspawn_deficit. P2/P3: shared pool, Mi-17 first. –Ю—В–њ—А–∞–≤–ї—П–µ—В QuotaDecision + LineAssignment."
    },
    {
      "order": 10,
      "phase": "–§–Р–Ч–Р 3: –Я—А–Є–Љ–µ–љ–µ–љ–Є–µ –Ї–≤–Њ—В",
      "layer": "demote_apply",
      "function": "rtc_ops_demote_v7",
      "state": "2вЖТ3",
      "notes": "cond: decision==demote. limiter=0 –њ—А–Є–љ—Г–і–Є—В–µ–ї—М–љ–Њ."
    },
    {
      "order": 11,
      "phase": "–§–Р–Ч–Р 3: –Я—А–Є–Љ–µ–љ–µ–љ–Є–µ –Ї–≤–Њ—В",
      "layer": "P1_apply",
      "function": "rtc_svc_to_ops_v7",
      "state": "3вЖТ2",
      "notes": "cond: decision==P1. PPR —Б–Њ—Е—А–∞–љ—П–µ—В—Б—П. limiter=0вЖТinline binary search."
    },
    {
      "order": 12,
      "phase": "–§–Р–Ч–Р 3: –Я—А–Є–Љ–µ–љ–µ–љ–Є–µ –Ї–≤–Њ—В",
      "layer": "P2_apply",
      "function": "rtc_unsvc_to_ops_v7",
      "state": "7вЖТ2",
      "notes": "cond: decision==P2. PPR=0. Inline limiter. QM —Г–ґ–µ –љ–∞–Ј–љ–∞—З–Є–ї line_id."
    },
    {
      "order": 13,
      "phase": "–§–Р–Ч–Р 3: –Я—А–Є–Љ–µ–љ–µ–љ–Є–µ –Ї–≤–Њ—В",
      "layer": "P3_apply",
      "function": "rtc_inactive_to_ops_v7",
      "state": "1вЖТ2",
      "notes": "cond: decision==P3. PPR –њ–Њ –њ—А–∞–≤–Є–ї—Г Mi-17. Inline limiter."
    },
    {
      "order": 14,
      "phase": "–§–Р–Ч–Р 3: –Я—А–Є–Љ–µ–љ–µ–љ–Є–µ –Ї–≤–Њ—В",
      "layer": "repair_line_apply_assign",
      "function": "rtc_repair_line_apply_assignment_v8",
      "state": "RepairLine",
      "notes": "RepairLine —З–Є—В–∞–µ—В LineAssignment: –Њ–±–љ–Њ–≤–ї—П–µ—В aircraft_number, –Њ–±–љ—Г–ї—П–µ—В free_days. Release: aircraft_number=0."
    },
    {
      "order": 15,
      "phase": "–§–Р–Ч–Р 4: –Ф–Є–љ–∞–Љ–Є—З–µ—Б–Ї–Є–є —Б–њ–∞–≤–љ",
      "layer": "spawn_ticket_mi17",
      "function": "rtc_spawn_dynamic_ticket_v8",
      "state": "0вЖТ2",
      "notes": "–°–Њ–Ј–і–∞—С—В –Э–Ю–Т–Ђ–• –∞–≥–µ–љ—В–Њ–≤ (Mi-17) –≤ ops –њ–Њ spawn_deficit. Inline limiter."
    },
    {
      "order": 16,
      "phase": "–§–Р–Ч–Р 4: –Ф–Є–љ–∞–Љ–Є—З–µ—Б–Ї–Є–є —Б–њ–∞–≤–љ",
      "layer": "spawn_ticket_mi8",
      "function": "rtc_spawn_dynamic_ticket_v8_mi8",
      "state": "0вЖТ2",
      "notes": "–°–Њ–Ј–і–∞—С—В –Э–Ю–Т–Ђ–• –∞–≥–µ–љ—В–Њ–≤ (Mi-8) –≤ ops –њ–Њ spawn_deficit. Inline limiter."
    },
    {
      "order": 17,
      "phase": "–§–Р–Ч–Р 5: Adaptive step (—Д–Є–љ–∞–ї)",
      "layer": "min_limiter_reduction",
      "function": "rtc_compute_min_limiter",
      "state": "2вЖТ2",
      "notes": "atomicMin –њ–Њ –≤—Б–µ–Љ ops вЖТ mp_min_limiter[0]. –°–±—А–Њ—Б –≤ HF_StepController."
    },
    {
      "order": "HF",
      "phase": "–§–Р–Ч–Р 5: Adaptive step (—Д–Є–љ–∞–ї)",
      "layer": "HF_StepController",
      "function": "HF_StepController",
      "state": "Host (step function)",
      "notes": "adaptive_days=MIN(mp_min_limiter, days_to_next_det). prev_day=current_day. current_day+=adaptive_days. Sync MacroPropertyвЖТEnvironment. Reset mp_min_limiter=0xFFFFFFFF."
    }
  ],

  "rules": [
    {
      "id": "spawn_to_ops_v9",
      "from": 0,
      "to": 2,
      "pre": {
        "expr": "ticket < spawn_dynamic_need_mi8 OR ticket < spawn_dynamic_need_mi17"
      },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "repair_days == 0" },
          { "expr": "repair_line_id == 0xFFFFFFFF" }
        ],
        "notes": "–Ф–Є–љ–∞–Љ–Є—З–µ—Б–Ї–Є–є spawn: –љ–Њ–≤—Л–є –∞–≥–µ–љ—В —Б—А–∞–Ј—Г –≤ ops. sne/ppr/idx/acn –Є–Ј SpawnMgr."
      },
      "owner_module": "rtc_spawn_dynamic_v7",
      "notes": "–Ф–Є–љ–∞–Љ–Є—З–µ—Б–Ї–Є–є spawn 0вЖТ2 (operations)."
    },
    {
      "id": "spawn_to_svc_v9",
      "from": 0,
      "to": 3,
      "pre": {
        "expr": "current_day >= exit_date"
      },
      "post": {
        "all": [
          { "expr": "state == 3" },
          { "expr": "limiter == 0" }
        ]
      },
      "owner_module": "rtc_spawn_to_svc",
      "notes": "–Ф–µ—В–µ—А–Љ–Є–љ–Є—А–Њ–≤–∞–љ–љ—Л–є spawn 0вЖТ3 (serviceable). P1 –њ–Њ–і–љ–Є–Љ–µ—В –≤ ops."
    },
    {
      "id": "ops_to_storage_ll_v8",
      "from": 2,
      "to": 6,
      "pre": { "expr": "sne_next >= ll" },
      "post": {
        "all": [
          { "expr": "state == 6" },
          { "expr": "limiter == 0" }
        ],
        "notes": "–Ґ–µ—А–Љ–Є–љ–∞–ї—М–љ–Њ–µ —Б–Њ—Б—В–Њ—П–љ–Є–µ: sne –Є ppr frozen"
      },
      "owner_module": "rtc_state_transitions_v8",
      "notes": "–°–њ–Є—Б–∞–љ–Є–µ –њ–Њ LL (next-day dt). –Я—А–Є–Њ—А–Є—В–µ—В 1."
    },
    {
      "id": "ops_to_storage_br_v8",
      "from": 2,
      "to": 6,
      "pre": { "expr": "ppr_next >= oh AND sne_next >= br" },
      "post": {
        "all": [
          { "expr": "state == 6" },
          { "expr": "limiter == 0" }
        ],
        "notes": "–Ґ–µ—А–Љ–Є–љ–∞–ї—М–љ–Њ–µ —Б–Њ—Б—В–Њ—П–љ–Є–µ: sne –Є ppr frozen"
      },
      "owner_module": "rtc_state_transitions_v8",
      "notes": "–°–њ–Є—Б–∞–љ–Є–µ –њ–Њ BR –њ—А–Є SNE>=BR. –Я—А–Є–Њ—А–Є—В–µ—В 2."
    },
    {
      "id": "ops_to_unsvc_v8",
      "from": 2,
      "to": 7,
      "pre": { "expr": "ppr_next >= oh AND sne_next < br" },
      "post": {
        "all": [
          { "expr": "state == 7" },
          { "expr": "repair_line_id == 0xFFFFFFFF" },
          { "expr": "repair_days == repair_time" }
        ]
      },
      "owner_module": "rtc_state_transitions_v8",
      "notes": "–£—Е–Њ–і –≤ unsvc –њ–Њ OH –њ—А–Є SNE<BR. repair_days=repair_time. –Я—А–Є–Њ—А–Є—В–µ—В 3."
    },
    {
      "id": "demote_ops_to_svc_v8",
      "from": 2,
      "to": 3,
      "pre": { "expr": "idx < demote_threshold" },
      "post": {
        "all": [
          { "expr": "state == 3" },
          { "expr": "limiter == 0" }
        ],
        "notes": "limiter –Њ–±–љ—Г–ї—П–µ—В—Б—П –њ—А–Є–љ—Г–і–Є—В–µ–ї—М–љ–Њ (–њ–µ—А–µ—Б—З–Є—В—Л–≤–∞–µ—В—Б—П –њ—А–Є re-entry —З–µ—А–µ–Ј P1)"
      },
      "owner_module": "rtc_demote_ops_v7",
      "notes": "–Ф–µ–Љ–Њ—Г—В opsвЖТsvc –њ—А–Є –Є–Ј–±—Л—В–Ї–µ (–њ–Њ idx)."
    },
    {
      "id": "p1_svc_to_ops_v8",
      "from": 3,
      "to": 2,
      "pre": { "expr": "idx >= threshold_s3 AND quota_left > 0" },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "limiter = compute_limiter_inline()" }
        ]
      },
      "owner_module": "rtc_svc_to_ops_v7",
      "notes": "P1: svcвЖТops. PPR —Б–Њ—Е—А–∞–љ—П–µ—В—Б—П. Inline limiter."
    },
    {
      "id": "p2_unsvc_to_ops_v8",
      "from": 7,
      "to": 2,
      "pre": { "expr": "repair_days == 0 AND repair_line_id == 0xFFFFFFFF AND free_days >= repair_time AND quota_left > 0" },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "ppr == 0" },
          { "expr": "repair_line_id = line_id" },
          { "expr": "repair_line.free_days = 0" },
          { "expr": "repair_line.aircraft_number = acn" },
          { "expr": "limiter = compute_limiter_inline()" }
        ]
      },
      "owner_module": "rtc_promote_unsvc_v8",
      "notes": "P2: unsvcвЖТops. PPR=0. RepairLine. Inline limiter."
    },
    {
      "id": "p3_inactive_to_ops_v8",
      "from": 1,
      "to": 2,
      "pre": { "expr": "free_days >= repair_time AND quota_left > 0" },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "repair_line_id = line_id" },
          { "expr": "repair_line.free_days = 0" },
          { "expr": "repair_line.aircraft_number = acn" },
          { "expr": "limiter = compute_limiter_inline()" }
        ]
      },
      "owner_module": "rtc_promote_inactive_v8",
      "notes": "P3: inactiveвЖТops. PPR –њ–Њ –њ—А–∞–≤–Є–ї—Г Mi-17. RepairLine. Inline limiter."
    },
    {
      "id": "repair_to_svc_v8",
      "from": 4,
      "to": 3,
      "pre": { "expr": "current_day >= exit_date" },
      "post": {
        "all": [
          { "expr": "state == 3" },
          { "expr": "repair_days == 0" }
        ]
      },
      "owner_module": "rtc_repair_to_svc_v7",
      "notes": "–Ф–µ—В–µ—А–Љ–Є–љ–Є—А–Њ–≤–∞–љ–љ—Л–є –≤—Л—Е–Њ–і –Є–Ј —А–µ–Љ–Њ–љ—В–∞ –њ–Њ exit_date."
    }
  ]
}
