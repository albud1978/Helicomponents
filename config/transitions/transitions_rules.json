      "state": "SpawnMgr",
      "notes": "Дефицит = target − curr_ops − used(P1/P2/P3 commit)"
    },
    {
      "order": 47,
      "phase": "ФАЗА 4: Динамический спавн",
      "layer": "v8_spawn_dynamic_ticket",
      "function": "rtc_spawn_dynamic_ticket_v8",
      "state": "Ticket→ops",
      "notes": "Создание новых агентов (Mi-17)"
    },
    {
      "order": 48,
      "phase": "ФАЗА 4: Динамический спавн",
      "layer": "v8_spawn_dynamic_ticket_mi8",
      "function": "rtc_spawn_dynamic_ticket_v8_mi8",
      "state": "Ticket→ops",
      "notes": "Создание новых агентов (Mi-8)"
    },
    {
      "order": 49,
