    },
    {
      "order": 40,
      "phase": "ФАЗА 3.7: Post-quota пересчёт",
      "layer": "v8_reset_buffers_post_quota",
      "function": "rtc_reset_quota_v8_post_*",
      "state": "all",
      "notes": "Сброс буферов после пост-квотных переходов"
    },
    {
      "order": 41,
      "phase": "ФАЗА 3.7: Post-quota пересчёт",
      "layer": "v8_count_agents_post_quota",
      "function": "rtc_count_*_v8_post",
      "state": "all",
      "notes": "Подсчёт ops/svc/unsvc/inactive после квот"
    },
    {
