      "layer": "v8_promote_inactive_bucket",
      "function": "rtc_promote_inactive_bucket_v8",
      "state": "1",
      "notes": "P3 решение по rank (MessageBucket)"
    },
    {
      "order": 33,
      "phase": "ФАЗА 2: Квотирование (MessageBucket)",
      "layer": "v8_promote_unsvc_commit",
      "function": "rtc_promote_unsvc_commit_v8",
      "state": "7",
      "notes": "Commit P2: бронирование RepairLine"
    },
