{
  "version": 10,
  "architecture": "LIMITER V8 (message-only quota + RepairLine bank + MP2 export + master-SSoT repairline occupancy overlay)",
  "matrix": {
    "from": "state",
    "to": "state"
  },
  "states": {
    "0": "spawn (boundary)",
    "1": "inactive",
    "2": "operations",
    "3": "serviceable",
    "4": "repair",
    "5": "reserve (legacy, не используется)",
    "6": "storage (terminal)",
    "7": "unserviceable"
  },
  "variables": [
    "state",
    "status_id",
    "pre_status_id",
    "status_change_day",
    "sne",
    "ppr",
    "dt_next",
    "rem_ll",
    "rem_oh",
    "ll",
    "oh",
    "br",
    "limiter",
    "repair_days",
    "repair_time",
    "repair_line_id",
    "repair_claim_start_day",
    "repair_claim_end_day",
    "repair_claim_source",
    "group_by",
    "current_day",
    "exit_date",
    "idx",
    "demote_threshold",
    "threshold_s3",
    "threshold_s7",
    "quota_left",
    "acn",
    "adaptive_days",
    "today_ready_slots",
    "bank_ready_slots",
    "today_committable_slots",
    "spawn_dynamic_need_mi17",
    "spawn_dynamic_need_mi8"
  ],
  "derived": [
    {
      "name": "sne_next",
      "expr": "sne + dt_next"
    },
    {
      "name": "ppr_next",
      "expr": "ppr + dt_next"
    }
  ],
  "init_at_model_build": {
    "description": "Инициализация выполняется в Python до simulate(), без legacy addStepFunction bootstrap.",
    "items": [
      "mp5_cumsum MacroProperty заполняется host-слоем layer_init_mp5_cumsum",
      "repair_line_* MacroProperty и bank-* инициализируются host-слоем layer_init_repair_lines",
      "V8 runtime day/mp инициализируются host-слоем layer_init_v8",
      "HF_StepController зарегистрирован как layer_step_controller (до transitions/quota)"
    ]
  },
  "rtc_execution_order": [
    { "order": 0, "phase": "Host init", "layer": "layer_init_mp5_cumsum", "function": "HF_InitMP5Cumsum", "state": "host", "notes": "Инициализация cumsum для dt_next." },
    { "order": 1, "phase": "Host init", "layer": "layer_init_repair_lines", "function": "HF_InitRepairLines", "state": "host", "notes": "Инициализация RepairLine + bank MacroProperty." },
    { "order": 2, "phase": "Host init", "layer": "layer_init_v8", "function": "HF_InitV8", "state": "host", "notes": "Инициализация current_day/adaptive окружения V8." },
    { "order": 3, "phase": "Day advance", "layer": "layer_step_controller", "function": "HF_StepController", "state": "host", "notes": "Продвижение current_day по mp_min_limiter предыдущего шага." },
    { "order": 4, "phase": "Pre snapshot", "layer": "layer_save_pre_status", "function": "rtc_save_pre_status_*", "state": "all active", "notes": "Снимок pre_status_id до любых transitions." },
    { "order": 5, "phase": "Deterministic spawn", "layer": "layer_det_spawn", "function": "HF_DeterministicSpawn", "state": "host", "notes": "Опциональный детерминированный spawn 0->3." },
    { "order": 6, "phase": "Phase 0", "layer": "v8_repair_line_assign_repair", "function": "rtc_repair_line_assign_repair_v8", "state": "4->4", "notes": "Синхронизация line_id при входе/нахождении в repair." },
    { "order": 7, "phase": "Phase 0", "layer": "v7_repair_to_svc", "function": "rtc_repair_to_svc_v7", "state": "4->4", "notes": "Postprocess: выход из ремонта выполняется вне runtime matrix (repair exit вне transitions rules)." },
    { "order": 8, "phase": "Phase 1", "layer": "v8_ops_increment", "function": "rtc_ops_increment_v8", "state": "2->2", "notes": "Инкремент sne/ppr с учетом adaptive_days/limiter." },
    { "order": 9, "phase": "Phase 1", "layer": "v8_unsvc_decrement", "function": "rtc_unsvc_decrement_v8", "state": "7->7", "notes": "Декремент repair_days у unserviceable." },
    { "order": 10, "phase": "Phase 1", "layer": "v8_ops_to_storage", "function": "rtc_ops_to_storage_v8", "state": "2->6", "notes": "Приоритет terminal routing." },
    { "order": 11, "phase": "Phase 1", "layer": "v8_ops_to_unsvc", "function": "rtc_ops_to_unsvc_v8", "state": "2->7", "notes": "Routing в unserviceable при unmet storage path." },
    { "order": 12, "phase": "Phase 1.5", "layer": "v8_repair_line_increment", "function": "rtc_repair_line_increment_v8", "state": "RepairLine", "notes": "free_days += adaptive_days." },
    { "order": 13, "phase": "Phase 1.5", "layer": "v8_repair_line_write", "function": "rtc_repair_line_write_v8", "state": "RepairLine", "notes": "Публикация состояния линий в MP для квотирования." },
    { "order": 14, "phase": "Phase 1.5", "layer": "v8_repair_line_publish_status", "function": "rtc_repair_line_publish_status_v8", "state": "RepairLine", "notes": "Публикация telemetry/status до quota phase." },
    { "order": 15, "phase": "Phase 2 quota", "layer": "v8_reset_flags", "function": "rtc_reset_flags_v8_*", "state": "all", "notes": "Сброс commit/repair_candidate/transitions флагов." },
    { "order": 16, "phase": "Phase 2 quota", "layer": "v8_reset_buffers", "function": "rtc_reset_quota_v8_*", "state": "all", "notes": "Сброс count/readiness буферов квотирования." },
    { "order": 17, "phase": "Phase 2 quota", "layer": "v8_count_ops", "function": "rtc_count_ops_v8", "state": "operations", "notes": "Count ops для Mi-8/Mi-17." },
    { "order": 18, "phase": "Phase 2 quota", "layer": "v8_count_svc", "function": "rtc_count_svc_v8", "state": "serviceable", "notes": "Count serviceable." },
    { "order": 19, "phase": "Phase 2 quota", "layer": "v8_count_unsvc", "function": "rtc_count_unsvc_v8", "state": "unserviceable", "notes": "Count ready unsvc (repair_days gate)." },
    { "order": 20, "phase": "Phase 2 quota", "layer": "v8_count_inactive", "function": "rtc_count_inactive_v8", "state": "inactive", "notes": "Count inactive." },
    { "order": 21, "phase": "Phase 2 quota", "layer": "v8_quota_manager_bucket", "function": "rtc_quota_manager_v8_bucket", "state": "quota agent", "notes": "Broadcast QuotaBucket; приоритет квот: P2_17 -> P3_17 -> P2_8 -> P3_8." },
    { "order": 22, "phase": "Phase 2 quota", "layer": "v8_demote", "function": "rtc_demote_ops_v8", "state": "operations", "notes": "Demote-кандидаты по threshold." },
    { "order": 23, "phase": "Phase 2 quota", "layer": "v8_promote_svc_bucket", "function": "rtc_promote_svc_bucket_v8", "state": "serviceable", "notes": "P1 кандидаты по QuotaBucket." },
    { "order": 24, "phase": "Phase 2 quota", "layer": "v8_promote_unsvc_bucket", "function": "rtc_promote_unsvc_bucket_v8", "state": "unserviceable", "notes": "P2 кандидаты; bank-only ranking при today_committable_slots==0 && bank_ready_slots>0." },
    { "order": 25, "phase": "Phase 2 quota", "layer": "v8_promote_inactive_bucket", "function": "rtc_promote_inactive_bucket_v8", "state": "inactive", "notes": "P3 кандидаты; bank-only ranking аналогично P2." },
    { "order": 26, "phase": "Phase 2 quota", "layer": "v8_repair_line_snapshot", "function": "rtc_repair_line_snapshot_v8", "state": "quota agent", "notes": "Снимок mutable MP в *_ro_mp перед commit." },
    { "order": 27, "phase": "Phase 2 quota", "layer": "v8_promote_unsvc_commit", "function": "rtc_promote_unsvc_commit_v8", "state": "unserviceable", "notes": "Line-first commit: source1(today) -> source2(bank,newest-first), binary bank lock." },
    { "order": 28, "phase": "Phase 2 quota", "layer": "v8_promote_inactive_commit", "function": "rtc_promote_inactive_commit_v8", "state": "inactive", "notes": "Line-first commit: source1(today) -> source2(bank,newest-first), binary bank lock." },
    { "order": 29, "phase": "Phase 3 apply", "layer": "v7_ops_demote", "function": "rtc_ops_demote_v7", "state": "2->3", "notes": "Применение demote." },
    { "order": 30, "phase": "Phase 3 apply", "layer": "v7_svc_to_ops", "function": "rtc_svc_to_ops_v7", "state": "3->2", "notes": "Применение P1." },
    { "order": 31, "phase": "Phase 3 apply", "layer": "v7_unsvc_to_ops", "function": "rtc_unsvc_to_ops_v7", "state": "7->2", "notes": "Применение P2 commit." },
    { "order": 32, "phase": "Phase 3 apply", "layer": "v7_inactive_to_ops", "function": "rtc_inactive_to_ops_v7", "state": "1->2", "notes": "Применение P3 commit." },
    { "order": 33, "phase": "Phase 3 apply", "layer": "v8_repair_line_apply_assignment", "function": "rtc_repair_line_apply_assignment_v8", "state": "RepairLine", "notes": "Финализация line assignment для telemetry." },
    { "order": 34, "phase": "Telemetry", "layer": "v8_repair_line_export", "function": "rtc_repair_line_export_v8", "state": "RepairLine", "notes": "Экспорт runtime telemetry линии (free_days/repair_time/acn/bank) в RL buffers; occupancy-семантика формируется на этапе CH export из master claim SSOT." },
    { "order": 35, "phase": "Post quota recount", "layer": "v8_reset_buffers_post_quota", "function": "rtc_reset_quota_v8_post_*", "state": "all", "notes": "Сброс post-quota count буферов." },
    { "order": 36, "phase": "Post quota recount", "layer": "v8_count_agents_post_quota", "function": "rtc_count_*_v8_post", "state": "ops/svc/unsvc/inactive", "notes": "Пересчет для корректного spawn." },
    { "order": 37, "phase": "Spawn recount", "layer": "v8_reset_buffers_spawn", "function": "rtc_reset_quota_v8_spawn_*", "state": "all", "notes": "Сброс spawn count буферов." },
    { "order": 38, "phase": "Spawn recount", "layer": "v8_count_agents_spawn", "function": "rtc_count_*_v8_spawn", "state": "ops/svc/unsvc/inactive", "notes": "Пересчет для dynamic spawn manager." },
    { "order": 39, "phase": "Phase 4 spawn", "layer": "v8_spawn_dynamic_mgr", "function": "rtc_spawn_dynamic_mgr_v8", "state": "SpawnDynamicMgr", "notes": "Расчет дефицита после P1/P2/P3 и запись spawn needs." },
    { "order": 40, "phase": "Phase 4 spawn", "layer": "v8_spawn_dynamic_ticket", "function": "rtc_spawn_dynamic_ticket_v8", "state": "SpawnDynamicTicket", "notes": "Создание Mi-17 dynamic 0->2." },
    { "order": 41, "phase": "Phase 4 spawn", "layer": "v8_spawn_dynamic_ticket_mi8", "function": "rtc_spawn_dynamic_ticket_v8_mi8", "state": "SpawnDynamicTicketMi8", "notes": "Создание Mi-8 dynamic 0->2." },
    { "order": 42, "phase": "Diagnostics", "layer": "layer_spawn_diag", "function": "HF_SpawnDiag", "state": "host", "notes": "Диагностический host layer spawn." },
    { "order": 43, "phase": "Limiter", "layer": "L_limiter_min", "function": "rtc_compute_min_limiter", "state": "2->2", "notes": "Подготовка mp_min_limiter для следующего day advance." },
    { "order": 44, "phase": "MP2 export", "layer": "layer_mp2_write", "function": "rtc_mp2_write_*", "state": "all active", "notes": "Запись агентных полей в MP2 буферы." },
    { "order": 45, "phase": "MP2 export", "layer": "layer_mp2_drain", "function": "HF_MP2_Drain", "state": "host", "notes": "Drain MP2 буферов в host dataframes." },
    { "order": 46, "phase": "RL export", "layer": "layer_repairline_drain", "function": "HF_RepairLineDrain", "state": "host", "notes": "Drain RL буферов (включая bank telemetry); при записи в sim_repairline_v9 occupancy накладывается из sim_masterv2_v9 (claim/claimless episodes)." },
    { "order": 47, "phase": "Sync day", "layer": "layer_sync_day_v5", "function": "HF_SyncDayV5", "state": "host", "notes": "Совместимость и финальный sync дня для simulate()." }
  ],
  "rules": [
    {
      "id": "spawn_to_ops_v8_dynamic",
      "from": 0,
      "to": 2,
      "pre": {
        "expr": "ticket < spawn_dynamic_need_mi17 OR ticket < spawn_dynamic_need_mi8"
      },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "repair_days == 0" },
          { "expr": "repair_line_id == 0xFFFFFFFF" }
        ],
        "notes": "Dynamic spawn по оставшемуся дефициту после quota phases."
      },
      "owner_module": "rtc_spawn_dynamic_v7",
      "notes": "Dynamic spawn 0->2."
    },
    {
      "id": "spawn_to_svc_deterministic",
      "from": 0,
      "to": 3,
      "pre": {
        "expr": "HF_DeterministicSpawn schedule hit"
      },
      "post": {
        "all": [
          { "expr": "state == 3" },
          { "expr": "limiter == 0" }
        ]
      },
      "owner_module": "orchestrator_limiter_v8",
      "notes": "Детерминированный spawn host-слоем layer_det_spawn."
    },
    {
      "id": "ops_to_storage_v8",
      "from": 2,
      "to": 6,
      "pre": { "expr": "limiter == 0 AND (sne >= ll OR (ppr >= oh AND sne >= br) OR (rem_ll <= rem_oh))" },
      "post": {
        "all": [
          { "expr": "state == 6" },
          { "expr": "limiter == 0" }
        ]
      },
      "owner_module": "rtc_state_transitions_v8",
      "notes": "Приоритет terminal routing."
    },
    {
      "id": "ops_to_unsvc_v8",
      "from": 2,
      "to": 7,
      "pre": { "expr": "limiter == 0 AND sne < ll AND ((ppr >= oh AND sne < br) OR rem_oh < rem_ll)" },
      "post": {
        "all": [
          { "expr": "state == 7" },
          { "expr": "repair_line_id == 0xFFFFFFFF" },
          { "expr": "repair_days == repair_time" }
        ]
      },
      "owner_module": "rtc_state_transitions_v8",
      "notes": "Маршрут в unserviceable при unmet storage path."
    },
    {
      "id": "ops_to_svc_demote_v7",
      "from": 2,
      "to": 3,
      "pre": { "expr": "needs_demote == 1" },
      "post": {
        "all": [
          { "expr": "state == 3" },
          { "expr": "transition_2_to_3 == 1" },
          { "expr": "limiter == 0" }
        ]
      },
      "owner_module": "rtc_state_transitions_v7",
      "notes": "Phase 3 apply demote: operations -> serviceable."
    },
    {
      "id": "svc_to_ops_p1_v7",
      "from": 3,
      "to": 2,
      "pre": { "expr": "promoted == 1" },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "transition_3_to_2 == 1" },
          { "expr": "commit_p1 == 1" }
        ]
      },
      "owner_module": "rtc_state_transitions_v7",
      "notes": "Phase 3 apply P1 promote: serviceable -> operations."
    },
    {
      "id": "p2_unsvc_to_ops_v8",
      "from": 7,
      "to": 2,
      "pre": { "expr": "repair_days == 0 AND repair_line_id == 0xFFFFFFFF AND quota_left > 0" },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "repair_claim_source in {1,2}" },
          { "expr": "repair_claim_start_day <= repair_claim_end_day" },
          { "expr": "ppr == 0" }
        ],
        "notes": "Source1 guard: status_change_day <= current_day - repair_time; source2 guard: status_change_day <= window_start."
      },
      "owner_module": "rtc_quota_v8",
      "notes": "Commit-порядок: source1(today best-fit) -> source2(bank newest-first, binary lock). Claim metadata является SSOT для восстановления repairline occupancy в export."
    },
    {
      "id": "p3_inactive_to_ops_v8",
      "from": 1,
      "to": 2,
      "pre": { "expr": "repair_line_id == 0xFFFFFFFF AND quota_left > 0" },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "repair_claim_source in {1,2}" },
          { "expr": "repair_claim_start_day <= repair_claim_end_day" }
        ],
        "notes": "Source1/source2 guards и line-first commit аналогичны P2."
      },
      "owner_module": "rtc_quota_v8",
      "notes": "Приоритет внутри QM type-first: Mi-17(P2->P3) затем Mi-8(P2->P3). Claim metadata является SSOT для восстановления repairline occupancy в export."
    }
  ]
}
