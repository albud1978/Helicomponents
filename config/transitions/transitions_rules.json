{
  "version": 8,
  "architecture": "LIMITER V8 (single-phase, RepairLine + Adaptive Steps)",
  "matrix": {
    "from": "state",
    "to": "state"
  },
  "states": {
    "0": "spawn (boundary)",
    "1": "inactive",
    "2": "operations",
    "3": "serviceable",
    "4": "repair",
    "5": "reserve (unused)",
    "6": "storage (terminal)",
    "7": "unserviceable"
  },
  "variables": [
    "state",
    "ticket",
    "intent_state",
    "sne",
    "ppr",
    "dt_next",
    "ll",
    "oh",
    "br",
    "limiter",
    "repair_days",
    "repair_time",
    "repair_line_id",
    "free_days",
    "group_by",
    "current_day",
    "exit_date",
    "idx",
    "threshold_s3",
    "threshold_s7",
    "threshold_s5",
    "demote_threshold",
    "quota_left",
    "line_id",
    "acn",
    "adaptive_days",
    "spawn_dynamic_need_mi8",
    "spawn_dynamic_need_mi17",
    "spawn_need_u32"
  ],
  "derived": [
    {
      "name": "sne_next",
      "expr": "sne + dt_next"
    },
    {
      "name": "ppr_next",
      "expr": "ppr + dt_next"
    }
  ],
  "rtc_execution_order": [
    {
