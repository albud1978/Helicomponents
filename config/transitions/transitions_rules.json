      "phase": "ФАЗА 2: Квотирование (MessageBucket)",
      "layer": "v8_promote_inactive_commit",
      "function": "rtc_promote_inactive_commit_v8",
      "state": "1",
      "notes": "Commit P3: бронирование RepairLine"
    },
    {
