{
  "version": 9,
  "architecture": "LIMITER V9 (message-based, 18 RTC + 1 HF_StepController)",
  "matrix": {
    "from": "state",
    "to": "state"
  },
  "states": {
    "0": "spawn (boundary)",
    "1": "inactive",
    "2": "operations",
    "3": "serviceable",
    "4": "repair",
    "5": "reserve (не используется в V9, рудимент V2)",
    "6": "storage (terminal)",
    "7": "unserviceable"
  },
  "variables": [
    "state",
    "ticket",
    "intent_state",
    "sne",
    "ppr",
    "dt_next",
    "ll",
    "oh",
    "br",
    "limiter",
    "repair_days",
    "repair_time",
    "repair_line_id",
    "free_days",
    "group_by",
    "current_day",
    "exit_date",
    "idx",
    "threshold_s3",
    "threshold_s7",
    "demote_threshold",
    "quota_left",
    "line_id",
    "acn",
    "adaptive_days",
    "spawn_dynamic_need_mi8",
    "spawn_dynamic_need_mi17",
    "spawn_need_u32"
  ],
  "derived": [
    {
      "name": "sne_next",
      "expr": "sne + dt_next"
    },
    {
      "name": "ppr_next",
      "expr": "ppr + dt_next"
    }
  ],

  "init_at_model_build": {
    "description": "Инициализация выполняется в Python ДО simulate(), заменяет старые HostFunction layers 0, 1, 13",
    "items": [
      "mp5_cumsum MacroProperty — заполнить из Python-списка кумулятивных часов",
      "deterministic_dates_mp — заполнить из финализированного списка дат",
      "RepairLine агенты — создать repair_quota штук, day-0 занятые привязать к агентам в state 4",
      "mp_min_limiter = 0xFFFFFFFF, current_day_mp, adaptive_result_mp — инициализировать"
    ]
  },

  "rtc_execution_order": [
    {
      "order": 0,
      "phase": "ФАЗА 0: Детерминированные переходы",
      "layer": "repair_to_svc",
      "function": "rtc_repair_to_svc_v7",
      "state": "4→3",
      "notes": "repair→serviceable по exit_date. PPR=0, limiter=0."
    },
    {
      "order": 1,
      "phase": "ФАЗА 0: Детерминированные переходы",
      "layer": "spawn_to_svc",
      "function": "rtc_spawn_to_svc",
      "state": "0→3",
      "notes": "Детерминированный spawn по exit_date → serviceable. PPR=0, SNE=0, limiter=0. P1 поднимет в ops."
    },
    {
      "order": 2,
      "phase": "ФАЗА 1: Operations и ремонтные счётчики",
      "layer": "ops_increment",
      "function": "rtc_ops_increment_v8",
      "state": "2→2",
      "notes": "effective_days=min(adaptive_days,limiter). dt=cumsum[prev_day+effective_days]-cumsum[prev_day]. SNE+=dt, PPR+=dt, limiter-=adaptive_days (clamp 0). Предотвращает overshoot sne>ll."
    },
    {
      "order": 3,
      "phase": "ФАЗА 1: Operations и ремонтные счётчики",
      "layer": "unsvc_decrement",
      "function": "rtc_unsvc_decrement_v8",
      "state": "7→7",
      "notes": "repair_days-=adaptive_days. Обратный отсчёт ремонтного окна."
    },
    {
      "order": 4,
      "phase": "ФАЗА 1: Operations и ремонтные счётчики",
      "layer": "ops_to_storage",
      "function": "rtc_ops_to_storage_v8",
      "state": "2→6",
      "notes": "cond: limiter==0 (sufficient). Routing: sne>=ll→storage; ppr>=oh&&sne>=br→storage; ppr>=oh&&sne<br→unsvc (handled by ops_to_unsvc); edge: rem_ll<=rem_oh→storage. Early-out: if limiter>0 return false."
    },
    {
      "order": 5,
      "phase": "ФАЗА 1: Operations и ремонтные счётчики",
      "layer": "ops_to_unsvc",
      "function": "rtc_ops_to_unsvc_v8",
      "state": "2→7",
      "notes": "cond: limiter==0 (sufficient). Routing: sne>=ll→false (storage priority); ppr>=oh&&sne<br→unsvc; edge: rem_oh<rem_ll→unsvc. Устанавливает repair_days=repair_time. Early-out: if limiter>0 return false."
    },
    {
      "order": 6,
      "phase": "ФАЗА 1.5: RepairLine pre-quota",
      "layer": "repair_line_increment",
      "function": "rtc_repair_line_increment_v8",
      "state": "RepairLine",
      "notes": "free_days+=adaptive_days."
    },
    {
      "order": 7,
      "phase": "ФАЗА 1.5: RepairLine pre-quota",
      "layer": "repair_line_publish",
      "function": "rtc_repair_line_publish_status_v8",
      "state": "RepairLine",
      "notes": "message RepairLineStatus: line_id, free_days. Только если free_days>=repair_time."
    },
    {
      "order": 8,
      "phase": "ФАЗА 2: Квотирование (message-based)",
      "layer": "publish_planer_report",
      "function": "rtc_publish_planer_report",
      "state": "all",
      "notes": "Каждый агент публикует статус через MessageBucket/MessageArray. Тип уточнить при реализации QM."
    },
    {
      "order": 9,
      "phase": "ФАЗА 2: Квотирование (message-based)",
      "layer": "QM_central_decision",
      "function": "rtc_quota_manager_v9",
      "state": "QM",
      "notes": "QM читает PlanerReport + RepairLineStatus. Каскадный дефицит: demote→P1→P2→P3→spawn_deficit. P2/P3: shared pool RepairLine slots. Приоритет слотов: P2_mi17→P2_mi8→P3_mi17→P3_mi8. При занятии слота free_days обнуляется. Прямой добор inactive→ops (post-promote) БЕЗ RepairLine ЗАПРЕЩЁН. Отправляет QuotaDecision + LineAssignment."
    },
    {
      "order": 10,
      "phase": "ФАЗА 3: Применение квот",
      "layer": "demote_apply",
      "function": "rtc_ops_demote_v7",
      "state": "2→3",
      "notes": "cond: decision==demote. limiter=0 принудительно."
    },
    {
      "order": 11,
      "phase": "ФАЗА 3: Применение квот",
      "layer": "P1_apply",
      "function": "rtc_svc_to_ops_v7",
      "state": "3→2",
      "notes": "cond: decision==P1. PPR сохраняется. limiter=0→inline binary search."
    },
    {
      "order": 12,
      "phase": "ФАЗА 3: Применение квот",
      "layer": "P2_apply",
      "function": "rtc_unsvc_to_ops_v7",
      "state": "7→2",
      "notes": "cond: decision==P2. PPR=0. Inline limiter. QM уже назначил line_id."
    },
    {
      "order": 13,
      "phase": "ФАЗА 3: Применение квот",
      "layer": "P3_apply",
      "function": "rtc_inactive_to_ops_v7",
      "state": "1→2",
      "notes": "cond: decision==P3. PPR по правилу Mi-17. Inline limiter."
    },
    {
      "order": 14,
      "phase": "ФАЗА 3: Применение квот",
      "layer": "repair_line_apply_assign",
      "function": "rtc_repair_line_apply_assignment_v8",
      "state": "RepairLine",
      "notes": "RepairLine читает LineAssignment: обновляет aircraft_number, обнуляет free_days. Release: aircraft_number=0."
    },
    {
      "order": 15,
      "phase": "ФАЗА 4: Динамический спавн",
      "layer": "spawn_ticket_mi17",
      "function": "rtc_spawn_dynamic_ticket_v8",
      "state": "0→2",
      "notes": "Создаёт НОВЫХ агентов (Mi-17) в ops по spawn_deficit. Inline limiter."
    },
    {
      "order": 16,
      "phase": "ФАЗА 4: Динамический спавн",
      "layer": "spawn_ticket_mi8",
      "function": "rtc_spawn_dynamic_ticket_v8_mi8",
      "state": "0→2",
      "notes": "Создаёт НОВЫХ агентов (Mi-8) в ops по spawn_deficit. Inline limiter."
    },
    {
      "order": 17,
      "phase": "ФАЗА 5: Adaptive step (финал)",
      "layer": "min_limiter_reduction",
      "function": "rtc_compute_min_limiter",
      "state": "2→2",
      "notes": "atomicMin по всем ops → mp_min_limiter[0]. Сброс в HF_StepController."
    },
    {
      "order": "HF",
      "phase": "ФАЗА 5: Adaptive step (финал)",
      "layer": "HF_StepController",
      "function": "HF_StepController",
      "state": "Host (step function)",
      "notes": "adaptive_days=MIN(mp_min_limiter, days_to_next_det). prev_day=current_day. current_day+=adaptive_days. Sync MacroProperty→Environment. Reset mp_min_limiter=0xFFFFFFFF."
    }
  ],

  "rules": [
    {
      "id": "spawn_to_ops_v9",
      "from": 0,
      "to": 2,
      "pre": {
        "expr": "ticket < spawn_dynamic_need_mi8 OR ticket < spawn_dynamic_need_mi17"
      },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "repair_days == 0" },
          { "expr": "repair_line_id == 0xFFFFFFFF" }
        ],
        "notes": "Динамический spawn: новый агент сразу в ops. sne/ppr/idx/acn из SpawnMgr."
      },
      "owner_module": "rtc_spawn_dynamic_v7",
      "notes": "Динамический spawn 0→2 (operations)."
    },
    {
      "id": "spawn_to_svc_v9",
      "from": 0,
      "to": 3,
      "pre": {
        "expr": "current_day >= exit_date"
      },
      "post": {
        "all": [
          { "expr": "state == 3" },
          { "expr": "limiter == 0" }
        ]
      },
      "owner_module": "rtc_spawn_to_svc",
      "notes": "Детерминированный spawn 0→3 (serviceable). P1 поднимет в ops."
    },
    {
      "id": "ops_to_storage_v8",
      "from": 2,
      "to": 6,
      "pre": { "expr": "limiter == 0 AND (sne >= ll OR (ppr >= oh AND sne >= br) OR (rem_ll <= rem_oh))" },
      "post": {
        "all": [
          { "expr": "state == 6" },
          { "expr": "limiter == 0" }
        ],
        "notes": "Терминальное состояние: sne и ppr frozen"
      },
      "owner_module": "rtc_state_transitions_v8",
      "notes": "limiter==0 — безусловный выход из ops. Маршрут в storage: sne>=ll (приоритет 1), ppr>=oh&&sne>=br (приоритет 2), edge case rem_ll<=rem_oh."
    },
    {
      "id": "ops_to_unsvc_v8",
      "from": 2,
      "to": 7,
      "pre": { "expr": "limiter == 0 AND sne < ll AND (ppr >= oh AND sne < br OR rem_oh < rem_ll)" },
      "post": {
        "all": [
          { "expr": "state == 7" },
          { "expr": "repair_line_id == 0xFFFFFFFF" },
          { "expr": "repair_days == repair_time" }
        ]
      },
      "owner_module": "rtc_state_transitions_v8",
      "notes": "limiter==0, sne<ll. Маршрут в unsvc: ppr>=oh&&sne<br (OH, ремонтопригоден), edge case rem_oh<rem_ll."
    },
    {
      "id": "demote_ops_to_svc_v8",
      "from": 2,
      "to": 3,
      "pre": { "expr": "idx < demote_threshold" },
      "post": {
        "all": [
          { "expr": "state == 3" },
          { "expr": "limiter == 0" }
        ],
        "notes": "limiter обнуляется принудительно (пересчитывается при re-entry через P1)"
      },
      "owner_module": "rtc_demote_ops_v7",
      "notes": "Демоут ops→svc при избытке (по idx)."
    },
    {
      "id": "p1_svc_to_ops_v8",
      "from": 3,
      "to": 2,
      "pre": { "expr": "idx >= threshold_s3 AND quota_left > 0" },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "limiter = compute_limiter_inline()" }
        ]
      },
      "owner_module": "rtc_svc_to_ops_v7",
      "notes": "P1: svc→ops. PPR сохраняется. Inline limiter."
    },
    {
      "id": "p2_unsvc_to_ops_v8",
      "from": 7,
      "to": 2,
      "pre": { "expr": "repair_days == 0 AND repair_line_id == 0xFFFFFFFF AND free_days >= repair_time AND quota_left > 0" },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "ppr == 0" },
          { "expr": "repair_line_id = line_id" },
          { "expr": "repair_line.free_days = 0" },
          { "expr": "repair_line.aircraft_number = acn" },
          { "expr": "limiter = compute_limiter_inline()" }
        ]
      },
      "owner_module": "rtc_promote_unsvc_v8",
      "notes": "P2: unsvc→ops. PPR=0. RepairLine. Inline limiter."
    },
    {
      "id": "p3_inactive_to_ops_v8",
      "from": 1,
      "to": 2,
      "pre": { "expr": "free_days >= repair_time AND quota_left > 0" },
      "post": {
        "all": [
          { "expr": "state == 2" },
          { "expr": "repair_line_id = line_id" },
          { "expr": "repair_line.free_days = 0" },
          { "expr": "repair_line.aircraft_number = acn" },
          { "expr": "limiter = compute_limiter_inline()" }
        ]
      },
      "owner_module": "rtc_promote_inactive_v8",
      "notes": "P3: inactive→ops. PPR по правилу Mi-17. RepairLine. Inline limiter."
    },
    {
      "id": "repair_to_svc_v8",
      "from": 4,
      "to": 3,
      "pre": { "expr": "current_day >= exit_date" },
      "post": {
        "all": [
          { "expr": "state == 3" },
          { "expr": "repair_days == 0" }
        ]
      },
      "owner_module": "rtc_repair_to_svc_v7",
      "notes": "Детерминированный выход из ремонта по exit_date."
    }
  ]
}
