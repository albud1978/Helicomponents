      "layer": "L_limiter_entry",
      "function": "rtc_compute_limiter_on_entry",
      "state": "2→2",
      "notes": "Пересчёт limiter при входе/нулевом значении"
    },
    {
      "order": 50,
      "phase": "ФАЗА 5: Limiter (бинарный поиск)",
      "layer": "L_limiter_min",
      "function": "rtc_compute_min_limiter",
      "state": "2→2",
      "notes": "Сбор минимального limiter по ops"
    }
  ],
  "rules": [
    {
      "id": "spawn_to_ops_v8",
      "from": 0,
      "to": 2,
      "pre": {
        "expr": "ticket < spawn_dynamic_need_mi8 OR ticket < spawn_dynamic_need_mi17"
      },
      "post": {
        "all": [
          {
            "expr": "state == 2"
          }
        ]
      },
      "owner_module": "rtc_spawn_dynamic_v7",
      "notes": "Динамический spawn → operations."
    },
    {
      "id": "spawn_to_svc_v2",
      "from": 0,
      "to": 3,
      "pre": {
        "expr": "ticket < spawn_need_u32"
      },
      "post": {
        "all": [
          {
            "expr": "state == 3"
          }
        ]
      },
      "owner_module": "rtc_spawn_v2",
      "notes": "Детерминированный spawn → serviceable."
    },
    {
      "id": "ops_to_storage_ll_v8",
      "from": 2,
      "to": 6,
      "pre": {
        "expr": "sne_next >= ll"
      },
      "post": {
        "all": [
          {
            "expr": "state == 6"
          },
          {
            "expr": "limiter == 0"
          }
        ]
      },
      "owner_module": "rtc_state_transitions_v8",
      "notes": "V8: списание по LL (next-day dt). Приоритет 1."
    },
    {
      "id": "ops_to_storage_br_v8",
      "from": 2,
      "to": 6,
      "pre": {
        "expr": "ppr_next >= oh AND sne_next >= br"
      },
      "post": {
        "all": [
          {
            "expr": "state == 6"
          },
          {
            "expr": "limiter == 0"
          }
        ]
      },
      "owner_module": "rtc_state_transitions_v8",
      "notes": "V8: списание по BR при SNE>=BR. Приоритет 2."
    },
    {
      "id": "ops_to_unsvc_v8",
      "from": 2,
      "to": 7,
      "pre": {
        "expr": "ppr_next >= oh AND sne_next < br"
      },
      "post": {
        "all": [
          {
            "expr": "state == 7"
          },
          {
            "expr": "repair_line_id == 0xFFFFFFFF"
          }
        ]
      },
      "owner_module": "rtc_state_transitions_v8",
      "notes": "V8: уход в unserviceable по OH при SNE<BR. Приоритет 3."
    },
    {
      "id": "demote_ops_to_svc_v8",
      "from": 2,
      "to": 3,
      "pre": {
        "expr": "idx < demote_threshold"
      },
      "post": {
        "all": [
          {
            "expr": "state == 3"
          }
        ]
      },
      "owner_module": "rtc_demote_ops_v7",
      "notes": "Квоты: демоут ops → serviceable при избытке (по idx)."
    },
    {
      "id": "p1_svc_to_ops_v8",
      "from": 3,
      "to": 2,
      "pre": {
        "expr": "idx >= threshold_s3 AND quota_left > 0"
      },
      "post": {
        "all": [
          {
            "expr": "state == 2"
          }
        ]
      },
      "owner_module": "rtc_svc_to_ops_v7",
      "notes": "Квоты P1: serviceable → operations (threshold_s3)."
    },
    {
      "id": "p2_unsvc_to_ops_v8",
      "from": 7,
      "to": 2,
      "pre": {
        "expr": "repair_days == 0 AND repair_line_id == 0xFFFFFFFF AND free_days >= repair_time AND quota_left > 0"
      },
      "post": {
        "all": [
          {
            "expr": "state == 2"
          },
          {
            "expr": "ppr == 0"
          },
          {
            "expr": "repair_line_id = line_id"
          },
          {
            "expr": "repair_line.free_days = 0"
          },
          {
            "expr": "repair_line.aircraft_number = acn"
          }
        ]
      },
      "owner_module": "rtc_promote_unsvc_v8",
      "notes": "Квоты P2: unserviceable → operations (RepairLine). repair_line.* — переменные агента RepairLine (MacroProperty)."
    },
    {
      "id": "p3_inactive_to_ops_v8",
      "from": 1,
      "to": 2,
      "pre": {
        "expr": "free_days >= repair_time AND quota_left > 0"
      },
      "post": {
        "all": [
          {
            "expr": "state == 2"
          },
          {
            "expr": "repair_line_id = line_id"
          },
          {
            "expr": "repair_line.free_days = 0"
          },
          {
            "expr": "repair_line.aircraft_number = acn"
          }
        ]
      },
      "owner_module": "rtc_promote_inactive_v8",
      "notes": "Квоты P3: inactive → operations (RepairLine). repair_line.* — переменные агента RepairLine (MacroProperty)."
    },
    {
      "id": "repair_to_svc_v8",
      "from": 4,
      "to": 3,
      "pre": {
        "expr": "current_day >= exit_date"
      },
      "post": {
        "all": [
          {
            "expr": "state == 3"
          },
          {
            "expr": "repair_days == 0"
          }
        ]
      },
      "owner_module": "rtc_repair_to_svc_v7",
      "notes": "Детерминированный выход из ремонта по exit_date."
    }
    
  ]
}
