{
  "nodes": [
    {
      "id": "transitions_spec",
      "label": "config/transitions/transitions_rules.json",
      "type": "Spec",
      "group": "Transitions",
      "version": 8,
      "architecture": "LIMITER V8 (single-phase, RepairLine + Adaptive Steps)",
      "matrix_from": "state",
      "matrix_to": "state"
    },
    { "id": "state_0", "label": "0 spawn (boundary)", "type": "State", "group": "States", "state_id": 0 },
    { "id": "state_1", "label": "1 inactive", "type": "State", "group": "States", "state_id": 1 },
    { "id": "state_2", "label": "2 operations", "type": "State", "group": "States", "state_id": 2 },
    { "id": "state_3", "label": "3 serviceable", "type": "State", "group": "States", "state_id": 3 },
    { "id": "state_4", "label": "4 repair", "type": "State", "group": "States", "state_id": 4 },
    { "id": "state_5", "label": "5 reserve (unused)", "type": "State", "group": "States", "state_id": 5 },
    { "id": "state_6", "label": "6 storage (terminal)", "type": "State", "group": "States", "state_id": 6 },
    { "id": "state_7", "label": "7 unserviceable", "type": "State", "group": "States", "state_id": 7 },

    {
      "id": "ops_to_storage_ll_v8",
      "label": "ops_to_storage_ll_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 2,
      "to": 6,
      "pre_expr": "sne_next >= ll",
      "post_exprs": ["state == 6", "limiter == 0"],
      "owner_module": "rtc_state_transitions_v8"
    },
    {
      "id": "ops_to_storage_br_v8",
      "label": "ops_to_storage_br_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 2,
      "to": 6,
      "pre_expr": "ppr_next >= oh AND br > 0 AND sne_next >= br",
      "post_exprs": ["state == 6", "limiter == 0"],
      "owner_module": "rtc_state_transitions_v8"
    },
    {
      "id": "ops_to_unsvc_v8",
      "label": "ops_to_unsvc_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 2,
      "to": 7,
      "pre_expr": "ppr_next >= oh AND NOT (br > 0 AND sne_next >= br)",
      "post_exprs": ["state == 7", "repair_line_id == 0xFFFFFFFF"],
      "owner_module": "rtc_state_transitions_v8"
    },
    {
      "id": "ops_hold_v8",
      "label": "ops_hold_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 2,
      "to": 2,
      "pre_expr": "sne_next < ll AND ppr_next < oh AND limiter > 0",
      "post_exprs": ["state == 2"],
      "owner_module": "rtc_state_transitions_v8"
    },
    {
      "id": "demote_ops_to_svc_v8",
      "label": "demote_ops_to_svc_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 2,
      "to": 3,
      "pre_expr": "idx < demote_threshold",
      "post_exprs": ["state == 3"],
      "owner_module": "rtc_demote_ops_v7"
    },
    {
      "id": "p1_svc_to_ops_v8",
      "label": "p1_svc_to_ops_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 3,
      "to": 2,
      "pre_expr": "idx >= threshold_s3 AND quota_left > 0",
      "post_exprs": ["state == 2"],
      "owner_module": "rtc_svc_to_ops_v7"
    },
    {
      "id": "p2_unsvc_to_ops_v8",
      "label": "p2_unsvc_to_ops_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 7,
      "to": 2,
      "pre_expr": "repair_days == 0 AND repair_line_id == 0xFFFFFFFF AND free_days >= repair_time AND quota_left > 0",
      "post_exprs": ["state == 2", "ppr == 0", "repair_line_id = line_id", "line.free_days = 0", "line.aircraft_number = acn"],
      "owner_module": "rtc_promote_unsvc_v8"
    },
    {
      "id": "p3_inactive_to_ops_v8",
      "label": "p3_inactive_to_ops_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 1,
      "to": 2,
      "pre_expr": "free_days >= repair_time AND quota_left > 0",
      "post_exprs": ["state == 2", "repair_line_id = line_id", "line.free_days = 0"],
      "owner_module": "rtc_promote_inactive_v8"
    },
    {
      "id": "repair_to_svc_v8",
      "label": "repair_to_svc_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 4,
      "to": 3,
      "pre_expr": "current_day >= exit_date",
      "post_exprs": ["state == 3", "repair_days == 0"],
      "owner_module": "rtc_repair_to_svc_v7"
    },
    {
      "id": "repair_hold_v8",
      "label": "repair_hold_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 4,
      "to": 4,
      "pre_expr": "current_day < exit_date",
      "post_exprs": ["state == 4"],
      "owner_module": "rtc_repair_to_svc_v7"
    },
    {
      "id": "serviceable_hold_v8",
      "label": "serviceable_hold_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 3,
      "to": 3,
      "pre_expr": "true",
      "post_exprs": ["state == 3"],
      "owner_module": "rtc_states_stub"
    },
    {
      "id": "unserviceable_hold_v8",
      "label": "unserviceable_hold_v8",
      "type": "Rule",
      "group": "Rules",
      "from": 7,
      "to": 7,
      "pre_expr": "true",
      "post_exprs": ["state == 7"],
      "owner_module": "rtc_states_stub"
    }
  ],
